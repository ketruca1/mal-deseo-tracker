# ═══════════════════════════════════════════════
# Mal Deseo — Launch Tracker
# Variables de entorno para Vercel + Turso
# ═══════════════════════════════════════════════

# ── Base de datos (Turso) ──────────────────
# Se obtiene al crear el proyecto en Turso
DATABASE_URL=libsql://mal-deseo-tuusuario.turso.io
DATABASE_AUTH_TOKEN=Tu_token_de_Turso_aqui

# ── Autenticación ───────────────────────────
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET=genera_uno_seguro_aqui

# ── Google OAuth (opcional) ─────────────────
# Solo si quieres login con Google
# GOOGLE_CLIENT_ID=tu_google_client_id
# GOOGLE_CLIENT_SECRET=tu_google_client_secret